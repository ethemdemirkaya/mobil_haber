YAPILACAKLAR.md

# Claude Code harness state (local only)
.claude/

# Gradle build tarafından .env.json'dan otomatik üretilen Dart dosyası.
# Koda gömülmez, her build'de yeniden oluşturulur.
lib/core/generated/

# Environment / secrets — Flutter --dart-define-from-file beklediği JSON.
# Şablon `.env.json.example` committed; `.env.json` her geliştiricinin
# kendi yerel kopyası, asla commit edilmez.
.env.json
.env
.env.local
.env.*.local

# Firebase — flutterfire configure tarafından üretilen platform config'leri.
# Public repo'ya pushlanmaz. Yeni geliştirici clone edince setup-firebase.ps1
# ile kendi Firebase projesinden tekrar üretir.
firebase.json
.firebaserc
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
macos/Runner/GoogleService-Info.plist
lib/firebase_options.dart